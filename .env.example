# Algorand Configuration
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
INDEXER_URL=https://testnet-idx.algonode.cloud
APP_ID=<deployed-app-id>

# Private Keys (NEVER commit these to GitHub!)
# Generate with: python -c "from algosdk import account; pk, addr = account.generate_account(); print(f'Private: {pk}\nAddress: {addr}')"
OWNER_PRIVATE_KEY=<your-owner-private-key-here>
ESTATE_AGENT_PRIVATE_KEY=<your-estate-agent-private-key-here>
NOMINEE_PRIVATE_KEY=<your-nominee-agent-private-key-here>

# Encryption Key for AES-256
# Generate with: python -c "import os; print(os.urandom(32).hex())"
VAULT_AES_KEY=<your-64-char-hex-aes-key-here>

# Demo Configuration
GRIEVANCE_SECONDS=30

# Optional: Twilio Integration (for SMS/WhatsApp notifications)
# TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
# TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
# TWILIO_PHONE_NUMBER=+1xxx

# Optional: DigiLocker Integration
# DIGILOCKER_API_KEY=<your-digilocker-api-key>

# Optional: Razorpay Integration
# RAZORPAY_KEY_ID=<your-razorpay-key>
# RAZORPAY_KEY_SECRET=<your-razorpay-secret>